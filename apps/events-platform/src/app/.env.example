# ── Supabase ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe ────────────────────────────────────────────────
STRIPE_SECRET_KEY=
# Register webhook at: https://dashboard.stripe.com/webhooks
# Endpoint: https://events.squarebidness.com/api/webhooks/stripe
# Events to subscribe: checkout.session.completed, checkout.session.expired,
#   payment_intent.payment_failed, charge.refunded
STRIPE_WEBHOOK_SECRET=

# ── App ───────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_SECRET=
NEXT_PUBLIC_APP_URL=https://events.squarebidness.com

# ── Admin ─────────────────────────────────────────────────
ADMIN_PASSWORD=
PLATFORM_ADMIN_EMAIL=

# ── Cron jobs ─────────────────────────────────────────────
# Must match the secret Vercel sends in the Authorization header for cron routes
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=

# ── Email (Resend) ────────────────────────────────────────
# Verify squarebidness.com domain in Resend dashboard
# Sends from: tickets@squarebidness.com and noreply@squarebidness.com
RESEND_API_KEY=

# ── SMS (Twilio) ──────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=       # E.164 format: +15551234567

# ── Rate limiting (Upstash Redis) ─────────────────────────
# Without these, rate limits are per-instance only (not safe on Vercel)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Cloudflare Turnstile (bot protection on checkout) ─────
# Optional: set TURNSTILE_REQUIRED=true to enforce
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
TURNSTILE_REQUIRED=false

# ── Web push notifications (VAPID) ────────────────────────
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
