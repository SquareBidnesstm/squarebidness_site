# ── Supabase ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe ────────────────────────────────────────────────
# IMPORTANT: rotate the key immediately if it was ever committed to .env.local
STRIPE_SECRET_KEY=
# Get from Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=
# Not currently used (Connect flow uses Express accounts, not OAuth)
STRIPE_CLIENT_ID=

# ── Resend (buyer confirmations, organizer alerts, waitlist) ──
RESEND_API_KEY=
RESEND_FROM=SB Events <noreply@squarebidness.com>

# ── Session auth ──────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_SECRET=

# ── Cron jobs ─────────────────────────────────────────────
# Must match the secret in vercel.json cron Authorization header
CRON_SECRET=

# ── Rate limiting (Upstash Redis) ─────────────────────────
# Without these, rate limits are per-instance only (not safe on Vercel)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Web push notifications (VAPID) ────────────────────────
# Generate with: npx web-push generate-vapid-keys
# IMPORTANT: missing VAPID keys crash the push notification route on first invocation
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ── App URLs ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://events.squarebidness.com
