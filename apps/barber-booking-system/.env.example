NEXT_PUBLIC_APP_NAME=Barber Booking System
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Supabase ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe ────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SOLO_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=

# ── Twilio SMS ────────────────────────────────────────────
# NOTE: code reads PLATFORM_FROM_NUMBER (not TWILIO_FROM_NUMBER)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
PLATFORM_FROM_NUMBER=

# ── Resend (email confirmations) ──────────────────────────
RESEND_API_KEY=
RESEND_FROM=

# ── Session auth ──────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_SECRET=

# ── Platform admin ────────────────────────────────────────
PLATFORM_PIN=
PLATFORM_ADMIN_EMAIL=

# ── Onboarding ────────────────────────────────────────────
# Set a long random secret; sent as Bearer token to POST /api/onboard
ONBOARD_SECRET=

# ── Cron jobs ─────────────────────────────────────────────
# Must match the secret in vercel.json cron Authorization header
CRON_SECRET=

# ── Rate limiting (Upstash Redis) ─────────────────────────
# Without these, rate limits are per-instance only (not safe on Vercel)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Web push notifications (VAPID) ────────────────────────
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ── Cloudflare Turnstile (bot protection on booking form) ─
# Leave blank to disable; set both to enable
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# Set to "true" to block submissions that fail Turnstile
TURNSTILE_REQUIRED=false

# ── Platform processing fee ───────────────────────────────
# Percentage taken from each Stripe transaction as platform revenue.
# Applied only when the shop has a connected account (transfer_data.destination set).
# Example: "2.5" = 2.5%. Leave blank or "0" to charge no platform fee.
PLATFORM_FEE_PERCENT=

# ── Error monitoring ──────────────────────────────────────
# Slack-compatible webhook for server error alerts (optional)
# Create at: your Slack workspace → Apps → Incoming Webhooks
ERROR_WEBHOOK_URL=
