NEXT_PUBLIC_APP_NAME=Barber Booking System
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Supabase ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe ────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SOLO_PRICE_ID=
STRIPE_PRO_PRICE_ID=

# ── Twilio SMS ────────────────────────────────────────────
# NOTE: code reads PLATFORM_FROM_NUMBER (not TWILIO_FROM_NUMBER)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
PLATFORM_FROM_NUMBER=

# ── Resend (email confirmations) ──────────────────────────
RESEND_API_KEY=
RESEND_FROM=

# ── Session auth ──────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_SECRET=

# ── Platform admin ────────────────────────────────────────
PLATFORM_PIN=

# ── Onboarding ────────────────────────────────────────────
# Set a long random secret; sent as Bearer token to POST /api/onboard
ONBOARD_SECRET=

# ── Cron jobs ─────────────────────────────────────────────
# Must match the secret in vercel.json cron Authorization header
CRON_SECRET=

# ── Rate limiting (Upstash Redis) ─────────────────────────
# Without these, rate limits are per-instance only (not safe on Vercel)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Web push notifications (VAPID) ────────────────────────
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
